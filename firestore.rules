rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write to drivers and orders
    match /drivers/{driverId} {
      allow read, write: if request.auth != null;
    }
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    // Allow reading of any collection for authenticated users (for debugging/admin)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
