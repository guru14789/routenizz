rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── Drivers: own data only; admins can do anything ─────────────────────────
    match /drivers/{driverId} {
      allow read, write: if isOwner(driverId) || isAdmin();
    }

    // ── Orders: any authenticated user can read; only admins can write ─────────
    match /orders/{orderId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Users: own profile only; admins can read all ───────────────────────────
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ── Routes: drivers can read their own route; admins have full access ──────
    match /routes/{vehicleId} {
      allow read:  if isOwner(vehicleId) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Weather alerts: any authenticated user can read; only backend writes ───
    match /weather_alerts/{alertId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── GPS telemetry: drivers write their own; admins read all ───────────────
    match /gps_heartbeats/{vehicleId} {
      allow read:  if isOwner(vehicleId) || isAdmin();
      allow write: if isOwner(vehicleId);
    }

    // ── Deny everything else by default ───────────────────────────────────────
    // No catch-all wildcard — fail-secure posture
  }
}
